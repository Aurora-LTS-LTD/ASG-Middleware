# =====================================================================
# Aurora LTS Accountant Portal — local env example
# =====================================================================
# Copy this file to .env.local and adjust as needed for your machine.
# .env.local is gitignored — never commit real values.

# Twin-Engine backends. Same DB + JWT secret, so one token works on both.
#   M1 (tax)  — Transparent Tax & Invoices server (aurora-api-tax)
#   M2 (core) — Premium AI Core & Copilot server  (aurora-api-core)
# Default is production. For local backend dev, point at http://localhost:8080.
NEXT_PUBLIC_AURORA_API_BASE=https://api-aurora-lts.com

# M2 core service base URL. aurora-api-core went live 2026-05-31 (v0.2.3).
# Stable Cloud Run URL shape (replace the PLACEHOLDER hash with the real one
# from `gcloud run services describe aurora-api-core --region me-west1
# --format='value(status.url)'`). Until this var is set, the client falls
# back to NEXT_PUBLIC_AURORA_API_BASE — which serves M2 routes via the M1
# shim, so copilot/native-shell calls will 404. Set this in .env.local.
NEXT_PUBLIC_AURORA_CORE_BASE=https://aurora-api-core-PLACEHOLDER-zf.a.run.app

# Set to "true" to use the mock API layer in src/lib/api/mock.ts
# (bypasses the real backend). Useful for Phase 3 UI iteration
# without needing valid accountant credentials.
#
# Magic test values when mocks are enabled:
#   • OTP: enter "123456" for success
#   • Email "locked@test.com" → triggers a simulated rate-limit (429)
NEXT_PUBLIC_USE_MOCK_API=false
