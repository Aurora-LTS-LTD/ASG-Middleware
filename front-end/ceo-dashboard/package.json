{
  "name": "aurora-ceo-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Aurora LTS CEO Dashboard — Tauri desktop app (macOS, internal distribution)",
  "scripts": {
    "tauri": "tauri",
    "dev": "npm run build:css && tauri dev",
    "build": "npm run build:css && tauri build",
    "build:css": "tailwindcss -i ./tailwind-input.css -o ./ui/tailwind.css --minify && cp ./ui/tailwind.css ./tailwind.css",
    "watch:css": "tailwindcss -i ./tailwind-input.css -o ./ui/tailwind.css --watch"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "tailwindcss": "^3.4.19"
  }
}
