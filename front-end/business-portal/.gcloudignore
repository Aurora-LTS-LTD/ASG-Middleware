# Files Cloud Build should NOT upload as part of the build context.
# (When `gcloud builds submit ./front-end/business-portal` runs, ONLY
# this directory is the upload context — the monorepo root's
# .gcloudignore does NOT apply.)

# Dependencies — installed fresh inside the build container via npm ci
node_modules/

# Next.js outputs — regenerated by `next build`
.next/
out/

# Firebase deploy state — regenerated by `firebase deploy`
.firebase/

# Local env (NEVER ship to the build context)
.env
.env.local
.env.*.local

# IDE / OS metadata
.vscode/
.idea/
.DS_Store
*.swp

# TS incremental build cache
*.tsbuildinfo

# Logs
*.log
