# Aurora Business Portal — environment template
# Copy to .env.local for local development:
#   cp .env.local.example .env.local
#
# Production builds (via cloudbuild.business-portal.yaml) inject these
# values at the `next build` step — static export inlines them into
# the JS bundle, so changing them requires a rebuild.

# REQUIRED — base URL of the Aurora main API (M1).
# Production: https://api-aurora-lts.com
# Local dev:  http://localhost:8000  (or the URL of your local API server)
NEXT_PUBLIC_AURORA_API_BASE=https://api-aurora-lts.com
