# ============================================================
# AURORA LTS LTD — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in real values.
# The .env file is in .gitignore and MUST NEVER be committed.
#
# Generate a secret:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# ============================================================

# --- Aurora Branding & Public URLs ---
COMPANY_NAME_HE=<your company name in Hebrew>
COMPANY_NAME_EN=<your company name in English>
PUBLIC_DOMAIN=<your domain e.g. aurora-ltd.co.il>
ONBOARDING_PUBLIC_URL=https://<domain>/onboarding

# --- Onboarding Module ---
GCS_BUCKET_KYC=<your GCS bucket for KYC documents e.g. asg-kyc-prod>
KYC_BACKEND=stub          # 'stub' for dev | 'gcs' for production
PAYPLUS_BACKEND=stub
OTP_BACKEND=stub
ONBOARDING_TRIAL_DAYS=14
KYC_MANUAL_REVIEW_FIRST_N=50

# GCS KYC service account key — required when KYC_BACKEND=gcs
# SA needs only roles/storage.objectCreator on GCS_BUCKET_KYC.
# Accepted: inline JSON string OR absolute path to the key file.
# Leave blank when KYC_BACKEND=stub (local dev).
GCS_KYC_SA_KEY_JSON=

# --- PayPlus Payment Gateway ---
PAYPLUS_API_KEY=<from PayPlus portal>
PAYPLUS_TERMINAL_NUMBER=<from PayPlus portal>
PAYPLUS_API_BASE=https://restapi.payplus.co.il/api/v1.0

# --- OTP Delivery ---
# OTP_BACKEND: 'stub' (dev — returns dev_only_code) | 'production' (real dispatch)
OTP_BACKEND=stub

# SMS_PROVIDER: 'stub' | 'inforu' (IL primary) | 'twilio' (international fallback)
SMS_PROVIDER=stub

# Inforu — Israeli SMS (cheapest for +972)
# API key from https://www.inforu.co.il account dashboard
INFORU_API_KEY=<from Inforu dashboard>
INFORU_SENDER_ID=Aurora

# Twilio — international SMS fallback
TWILIO_ACCOUNT_SID=<from https://console.twilio.com>
TWILIO_AUTH_TOKEN=<from https://console.twilio.com>
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# WhatsApp OTP template (Meta Business Manager > Message Templates)
# Leave blank to skip WhatsApp tier and go straight to SMS.
WHATSAPP_OTP_TEMPLATE_NAME=

# SendGrid — transactional email (OTPs, alerts)
# API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=<from SendGrid dashboard>
SENDGRID_FROM=otp@<your domain>
SENDGRID_FROM_NAME=<your company name>

EMAIL_FROM=noreply@<your domain>
INVITATION_TTL_HOURS=72

# --- WhatsApp Business API ---
# Generate WHATSAPP_VERIFY_TOKEN yourself — set this same value in Meta Developer Dashboard
# under WhatsApp > Configuration > Webhook > Verify Token.
WHATSAPP_VERIFY_TOKEN=<generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))">
WHATSAPP_ACCESS_TOKEN=<from Meta Developer Dashboard — System User token>
WHATSAPP_PHONE_NUMBER_ID=<numeric string from Meta Developer Dashboard>
WHATSAPP_APP_SECRET=<from Meta Developer Dashboard > App > Settings > Basic > App Secret>
WHATSAPP_WEBHOOK_SECRET=<generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))">
WHATSAPP_API_VERSION=v20.0
WHATSAPP_BOT_PHONE_E164=+972XXXXXXXXX

# --- Auth & Security ---
# REQUIRED: generate all four. Placeholder values will cause a
# WARNING in dev mode and a hard crash on Cloud Run.

# Signs all JWTs. Anyone with this key can impersonate any user.
JWT_SECRET=<generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))">
JWT_EXPIRATION_HOURS=24

# Signs WebAuthn step-up (break-glass) tokens.
WEBAUTHN_STEP_UP_SECRET=<generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))">

# Salt for one-way IP address hashing (privacy + audit logs).
AURORA_IP_HASH_SALT=<generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))">

# --- Dev Admin Seed (LOCAL DEV ONLY — never set on Cloud Run) ---
# These are used to auto-create the first admin on a fresh local database.
# The main.py startup block is skipped entirely when AURORA_RUNTIME=cloud_run.
AURORA_SEED_ADMIN_EMAIL=dev-admin@aurora-lts.local
AURORA_SEED_ADMIN_PASSWORD=<generate: python3 -c "import secrets; print(secrets.token_urlsafe(16))">

# --- Database ---
# Local dev: sqlite:///./aurora_dev.db
# Production: postgresql+psycopg2://user:pass@/dbname?host=/cloudsql/...
DATABASE_URL=sqlite:///./aurora_dev.db

# --- GCP / Cloud Run ---
# Set AURORA_RUNTIME=cloud_run on the Cloud Run service.
# Leave unset for local development.
AURORA_RUNTIME=

# DB connection pool (production tuning — leave blank to use defaults).
# P1-03 defaults are conservative: pool_size=5, max_overflow=5 per worker.
# Worst-case connections = (POOL_SIZE + MAX_OVERFLOW) × WORKERS × MAX_INSTANCES
# Must stay ≤ 80% of AURORA_CLOUD_SQL_MAX_CONNECTIONS or startup will WARN.
AURORA_DB_POOL_SIZE=5
AURORA_DB_MAX_OVERFLOW=5
AURORA_DB_POOL_RECYCLE=1800

# Cloud SQL connection ceiling (set to match your Cloud SQL tier).
#   db-custom-1-3840 → 100    db-custom-2-7680 → 200
#   db-custom-4-15360 → 400   db-custom-8-30720 → 500
AURORA_CLOUD_SQL_MAX_CONNECTIONS=100

# Cloud Run max-instances cap (must match `gcloud run deploy --max-instances`).
AURORA_CLOUD_RUN_MAX_INSTANCES=10

# Must match `gunicorn -w N` in Dockerfile (currently 2).
AURORA_GUNICORN_WORKERS=2

# --- Feature Flags / Backend Selectors ---
# All default to 'stub' for safe local dev. Change for production.
ITA_BACKEND=mock
STORAGE_BACKEND=stub
OCR_BACKEND=stub
DLP_BACKEND=stub
AUDIT_BIGQUERY_BACKEND=stub
GEMINI_BACKEND=stub
KYC_BACKEND=stub
OTP_BACKEND=stub
PAYPLUS_BACKEND=stub

# --- Rate Limiting (P0-09 — slowapi) ---
# memory = dev/single-instance (no extra infra)
# redis  = production Cloud Run (shared counter across all instances)
RATE_LIMIT_BACKEND=memory
# Required only when RATE_LIMIT_BACKEND=redis.
# GCP: use Cloud Memorystore (redis://10.x.x.x:6379 — internal VPC address)
REDIS_URL=redis://localhost:6379

# --- Make.com (optional relay) ---
MAKE_WEBHOOK_URL=<from Make.com > Scenario > Webhook module>

# --- Telegram Bot (optional) ---
TELEGRAM_BOT_TOKEN=<from @BotFather on Telegram>
TELEGRAM_WEBHOOK_SECRET=<generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))">
