# =====================================================================
# AURORA LTS LTD — PRODUCTION ENV VAR INVENTORY
# =====================================================================
# This file is DOCUMENTATION ONLY. Do NOT load it on Cloud Run.
#
# In production, every value below is set via either:
#   (a) `gcloud run deploy --set-env-vars=KEY=VALUE,...`   (config)
#   (b) `gcloud run deploy --set-secrets=KEY=SECRET:latest,...`  (secrets)
#
# The Cloud Run runtime injects each as a normal environment variable
# the app reads via `os.getenv(KEY)` — same code path as local dev.
#
# Maintenance rule: every NEW secret added to the codebase must be:
#   1. Created in Secret Manager with `gcloud secrets create AURORA_<NAME>`
#   2. Added to the `--set-secrets=` clause in the Cloud Run deploy command
#   3. Documented here under the appropriate section
# =====================================================================


# ───────────────────────────────────────────────────────────────────
# RUNTIME / PLATFORM (set via --set-env-vars=, NOT secrets)
# ───────────────────────────────────────────────────────────────────
AURORA_RUNTIME=cloud_run
PORT=8080
SKIP_SEED_ADMIN=1                      # blocks the dev admin@asg.com seed

# Filesystem paths (Cloud Run is read-only except /tmp; defaults match)
PDF_STORAGE_PATH=/tmp/aurora/pdfs
KYC_STUB_DIR=/tmp/aurora/kyc_uploads


# ───────────────────────────────────────────────────────────────────
# BRANDING + PUBLIC URLS (--set-env-vars=)
# ───────────────────────────────────────────────────────────────────
COMPANY_NAME_HE=אורורה אל.טי.אס. בע"מ
COMPANY_NAME_EN=AURORA LTS LTD
PUBLIC_DOMAIN=aurora-ltd.co.il
SERVER_BASE_URL=https://aurora-ltd.co.il
ONBOARDING_PUBLIC_URL=https://aurora-ltd.co.il/onboarding


# ───────────────────────────────────────────────────────────────────
# DATABASE (Cloud SQL Postgres)
# ───────────────────────────────────────────────────────────────────
# Format example (the real value is in Secret Manager):
#   postgresql+psycopg://aurora_app:<password>@/aurora_prod?host=/cloudsql/<PROJECT>:me-west1:aurora-pg
DATABASE_URL=__from_secret__AURORA_DATABASE_URL

# Pool tuning — leave at defaults unless under load
# AURORA_DB_POOL_SIZE=10
# AURORA_DB_MAX_OVERFLOW=20
# AURORA_DB_POOL_RECYCLE=1800


# ───────────────────────────────────────────────────────────────────
# AUTH / JWT (--set-secrets=)
# ───────────────────────────────────────────────────────────────────
JWT_SECRET=__from_secret__AURORA_JWT_SECRET
JWT_EXPIRATION_HOURS=24


# ───────────────────────────────────────────────────────────────────
# WHATSAPP (Meta Cloud API)
# ───────────────────────────────────────────────────────────────────
# Webhook is publicly registered as
#   https://aurora-ltd.co.il/webhook/whatsapp/{WHATSAPP_WEBHOOK_SECRET}
WHATSAPP_VERIFY_TOKEN=__from_secret__AURORA_WHATSAPP_VERIFY_TOKEN
WHATSAPP_ACCESS_TOKEN=__from_secret__AURORA_WHATSAPP_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=__from_secret__AURORA_WHATSAPP_PHONE_NUMBER_ID
WHATSAPP_APP_SECRET=__from_secret__AURORA_WHATSAPP_APP_SECRET
WHATSAPP_WEBHOOK_SECRET=__from_secret__AURORA_WHATSAPP_WEBHOOK_SECRET
WHATSAPP_BOT_PHONE_E164=__from_secret__AURORA_WHATSAPP_BOT_PHONE_E164
WHATSAPP_API_VERSION=v20.0
# Mock-inbound endpoint is auto-disabled when WHATSAPP_ACCESS_TOKEN is real
# (i.e. not "YOUR_..._HERE"). Optionally force-disable with:
# WA_MOCK_INBOUND_ENABLED=0


# ───────────────────────────────────────────────────────────────────
# TELEGRAM (legacy bot — DECISION PENDING: stays on Alienware for now)
# ───────────────────────────────────────────────────────────────────
# Set these only if Telegram migrates to Cloud Run. Otherwise leave unset
# so the startup block at app/main.py:on_startup skips bot init.
# TELEGRAM_BOT_TOKEN=__from_secret__AURORA_TELEGRAM_BOT_TOKEN
# TELEGRAM_WEBHOOK_SECRET=__from_secret__AURORA_TELEGRAM_WEBHOOK_SECRET


# ───────────────────────────────────────────────────────────────────
# ONBOARDING MODULE — feature flags + provider switches
# ───────────────────────────────────────────────────────────────────
KYC_BACKEND=stub                 # "stub" until Sprint 2 ships GCS
PAYPLUS_BACKEND=stub             # "production" once PayPlus creds land
OTP_BACKEND=stub                 # "inforu" / "twilio" once SMS provider chosen
ONBOARDING_TRIAL_DAYS=14
KYC_MANUAL_REVIEW_FIRST_N=50
INVITATION_TTL_HOURS=72


# ───────────────────────────────────────────────────────────────────
# PAYPLUS (--set-secrets=, only when KYC_BACKEND/PAYPLUS_BACKEND=production)
# ───────────────────────────────────────────────────────────────────
# PAYPLUS_API_KEY=__from_secret__AURORA_PAYPLUS_API_KEY
# PAYPLUS_TERMINAL_NUMBER=__from_secret__AURORA_PAYPLUS_TERMINAL_NUMBER
# PAYPLUS_API_BASE=https://restapi.payplus.co.il/api/v1.0


# ───────────────────────────────────────────────────────────────────
# SMS / EMAIL OTP (set when provider chosen)
# ───────────────────────────────────────────────────────────────────
# SMS_PROVIDER_API_KEY=__from_secret__AURORA_SMS_PROVIDER_API_KEY
# EMAIL_FROM=noreply@aurora-ltd.co.il


# ───────────────────────────────────────────────────────────────────
# GCS BUCKETS
# ───────────────────────────────────────────────────────────────────
GCS_BUCKET_KYC=asg-kyc-prod
GCS_BUCKET_RECEIPTS=asg-receipts-prod    # Sprint 2 (Document AI)
# GCS_BUCKET_PDFS=asg-pdfs-prod          # invoices PDFs migration


# ───────────────────────────────────────────────────────────────────
# DOCUMENT AI / OCR / DLP / Receipt Pipeline (Sprint 2)
# ───────────────────────────────────────────────────────────────────
# Backend selectors. Stub-default lets the WhatsApp Receipt Box flow
# run end-to-end on Cloud Run BEFORE GCS / Document AI / DLP are
# provisioned. Flip each to its production value once the runbook
# Phase 6+ steps have created the bucket + processor.
STORAGE_BACKEND=stub                     # 'stub' | 'gcs'
OCR_BACKEND=stub                         # 'stub' | 'documentai'
DLP_BACKEND=stub                         # 'stub' | 'gcp'

# Document AI processor coordinates (only used when OCR_BACKEND=documentai)
# DOCUMENT_AI_LOCATION=me-west1
# DOCUMENT_AI_EXPENSE_PROCESSOR_ID=__set_after_processor_creation__

# Confidence thresholds — tuned against Track C labeled corpus when ready.
# Default conservative; lower the auto threshold once accuracy is proven.
RECEIPT_CONFIDENCE_AUTO_THRESHOLD=0.85
RECEIPT_CONFIDENCE_REVIEW_THRESHOLD=0.60


# ───────────────────────────────────────────────────────────────────
# REAL ITA CLIENT (Sprint 3)
# ───────────────────────────────────────────────────────────────────
# Backend selector. 'mock' (default) routes to ita_mock_service —
# perfect for the Cloud Run image to run BEFORE ITA Software-House
# certification credentials arrive. Flip to 'production' once the
# ITA test/prod credentials are available.
ITA_BACKEND=mock                          # 'mock' | 'production'

# Production-only — used when ITA_BACKEND=production
ITA_API_BASE=https://ita.gov.il/api       # Real endpoint per ITA technical manual
ITA_ALLOCATION_PATH=/allocation/v1/issue  # Allocation request path
ITA_TIMEOUT_SECONDS=15
ITA_AUDIENCE=ita.gov.il                   # JWT 'aud' claim
ITA_JWT_TTL_SECONDS=300

# ITA-issued software-house identifier (issued at certification time;
# baked into the JWT 'iss' claim). Stays empty until paperwork lands.
# ITA_SOFTWARE_HOUSE_ID=__set_after_certification__

# Private signing key. Stored in Secret Manager — Cloud Run reads it
# via --set-secrets=AURORA_ITA_PRIVATE_KEY=AURORA_ITA_PRIVATE_KEY:latest
# ITA_PRIVATE_KEY_SECRET=AURORA_ITA_PRIVATE_KEY


# ───────────────────────────────────────────────────────────────────
# SECRET MANAGER WRAPPER (Sprint 3)
# ───────────────────────────────────────────────────────────────────
# 'env' (default) reads secrets from os.getenv() — fine for Cloud Run
# because --set-secrets= materialises Secret Manager values as env vars.
# 'gcp' reads directly via google-cloud-secret-manager — only needed for
# runtime rotation without a redeploy.
SECRET_BACKEND=env                        # 'env' | 'gcp'
SECRET_TTL_SECONDS=300                    # In-process cache TTL


# ───────────────────────────────────────────────────────────────────
# WEBHOOK HMAC HARDENING (Sprint 3)
# ───────────────────────────────────────────────────────────────────
# When AURORA_RUNTIME=cloud_run, HMAC signature verification is REQUIRED.
# A missing or placeholder WHATSAPP_APP_SECRET → webhook returns 403.
# Set this explicitly to '1' to force enforcement in any environment.
# WA_REQUIRE_SIGNATURE=1


# ───────────────────────────────────────────────────────────────────
# REVENUE SHARE ENGINE (Sprint 5)
# ───────────────────────────────────────────────────────────────────
REVENUE_SHARE_DEFAULT_PCT=20.0
REVENUE_SHARE_MIN_TENANT_DAYS=90
REVENUE_SHARE_MIN_INVOICES=5

# Cloud Scheduler / internal job authentication. ANY caller of
# /api/v1/internal/* must present this header. Stored in Secret Manager.
# AURORA_INTERNAL_TOKEN=__from_secret__AURORA_INTERNAL_TOKEN


# ───────────────────────────────────────────────────────────────────
# COMPLIANCE / HARDENING (Sprint 6)
# ───────────────────────────────────────────────────────────────────
# BigQuery audit pipeline backend selector
AUDIT_BIGQUERY_BACKEND=stub               # 'stub' | 'gcp'
BIGQUERY_AUDIT_DATASET=asg_audit          # only when backend=gcp

# Override flag (admin-only, USE SPARINGLY) — when set to '1' the
# immutability guards on terminal-state rows are bypassed. Use only
# during data-fix incidents under audit oversight.
# AURORA_AUDIT_ALLOW_OVERRIDE=0


# ───────────────────────────────────────────────────────────────────
# GEMINI / VERTEX AI (Product Upgrade #1 — auto-categorisation)
# ───────────────────────────────────────────────────────────────────
GEMINI_BACKEND=stub                       # 'stub' | 'vertex'
GEMINI_MODEL=gemini-2.0-flash
VERTEX_AI_LOCATION=me-west1

# Daily budget in agorot — once exhausted, falls back to keyword heuristic
GEMINI_DAILY_BUDGET_CENTS=5000            # ₪50/day default
GEMINI_MAX_INPUT_CHARS=1500


# ───────────────────────────────────────────────────────────────────
# BOOTSTRAP ADMIN (Cloud Run Job — see scripts/bootstrap_admin.py)
# ───────────────────────────────────────────────────────────────────
# These are passed only to the one-shot bootstrap job, NOT to the main
# api service. Rotate ADMIN_INITIAL_PASSWORD after first login.
# ADMIN_EMAIL=__from_secret__AURORA_ADMIN_EMAIL
# ADMIN_INITIAL_PASSWORD=__from_secret__AURORA_ADMIN_INITIAL_PASSWORD
# ADMIN_FULL_NAME=Ibrahim Masarwa
# ADMIN_LANGUAGE_PREF=he


# =====================================================================
# CHEAT SHEET — gcloud commands for the Secret Manager bindings
# =====================================================================
#
# Create all secrets (one-time, replace VALUE inline):
#   gcloud secrets create AURORA_DATABASE_URL                --replication-policy=automatic
#   gcloud secrets create AURORA_JWT_SECRET                  --replication-policy=automatic
#   gcloud secrets create AURORA_WHATSAPP_VERIFY_TOKEN       --replication-policy=automatic
#   gcloud secrets create AURORA_WHATSAPP_ACCESS_TOKEN       --replication-policy=automatic
#   gcloud secrets create AURORA_WHATSAPP_PHONE_NUMBER_ID    --replication-policy=automatic
#   gcloud secrets create AURORA_WHATSAPP_APP_SECRET         --replication-policy=automatic
#   gcloud secrets create AURORA_WHATSAPP_WEBHOOK_SECRET     --replication-policy=automatic
#   gcloud secrets create AURORA_WHATSAPP_BOT_PHONE_E164     --replication-policy=automatic
#
# Add a version (required before --set-secrets= can use them):
#   echo -n "<VALUE>" | gcloud secrets versions add AURORA_<NAME> --data-file=-
#
# Grant the Cloud Run service account read access (one-time per secret):
#   gcloud secrets add-iam-policy-binding AURORA_<NAME> \
#       --member=serviceAccount:aurora-run@<PROJECT>.iam.gserviceaccount.com \
#       --role=roles/secretmanager.secretAccessor
