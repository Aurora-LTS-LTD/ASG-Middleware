# =============================================================================
# Aurora LTS — NON-PROD / SANDBOX environment manifest (aurora-main-api)
# =============================================================================
# Purpose: validate REAL end-to-end onboarding (signup → OTP → KYC → payment →
# activate) against SANDBOX providers, without touching the live processor or
# sending real customer email/SMS.
#
# RULES:
#   • This file is a TEMPLATE. It contains NO credential values — secrets are
#     referenced by Secret Manager name and injected at deploy time.
#   • Apply to the NON-PROD Cloud Run service only (never prod).
#   • Secrets are materialized as env vars via `gcloud run deploy --set-secrets`
#     (SECRET_BACKEND stays `env`). Plaintext selectors via `--set-env-vars`.
#
# IMPORTANT MECHANISM NOTE:
#   The committed cloudbuild.yaml / Terraform do NOT yet inject any of these
#   (see the hardening report — H8/H9). Until they do, set them with an explicit
#   `gcloud run deploy` (example at the bottom). A pipeline deploy will otherwise
#   ship Dockerfile defaults (everything reverts to stub).
# =============================================================================

# ── Backend selectors (plaintext --set-env-vars) ─────────────────────────────
OTP_BACKEND=production            # enables WhatsApp→SMS→SendGrid dispatch (stub disables + echoes dev_only_code)
KYC_BACKEND=gcs                   # ⚠ value is "gcs" — NOT "gcp" (gcp raises ValueError on every upload)
PAYPLUS_BACKEND=production        # no dedicated "sandbox" selector — point PAYPLUS_API_BASE at the sandbox host
SMS_PROVIDER=stub                 # sandbox phone posture: keep SMS log-only; flip to inforu/twilio only to test SMS
SECRET_BACKEND=env                # Cloud Run --set-secrets materializes SM values as env vars
AURORA_RUNTIME=cloud_run          # NOTE: forces +972-only phone OTP and disables the dev_only_code shortcut
ONBOARDING_REQUIRE_PHONE_OTP=false # TEMP: skip the phone_otp step while the SMS provider is pending approval.
                                   # Reversible — set back to true (or unset) to re-enable phone verification.
                                   # Email OTP (SendGrid) still runs; phone code/endpoints are untouched.

# ── Email OTP — SendGrid ─────────────────────────────────────────────────────
# SECRET: --set-secrets SENDGRID_API_KEY=sendgrid-api-key:latest   (sandbox subuser key)
# Tip: a non-prod key + sandbox_mode validates sends without delivering.
SENDGRID_FROM=otp@sandbox.aurora-lts.example       # a verified sender on the sandbox subuser
SENDGRID_FROM_NAME=Aurora LTS (sandbox)

# ── Phone OTP Tier-1 — WhatsApp (Meta Graph). Omit the trio to force SMS fallback ─
# SECRET: --set-secrets WHATSAPP_ACCESS_TOKEN=whatsapp-access-token:latest  (Meta TEST-number token)
# WHATSAPP_PHONE_NUMBER_ID=<meta test phone-number id>     # plaintext; leave unset in sandbox to skip WhatsApp
# WHATSAPP_OTP_TEMPLATE_NAME=<approved auth template>      # leave UNSET to skip WhatsApp + exercise SMS fallback
# WHATSAPP_API_VERSION=v20.0                               # default; only pin if the sandbox app differs

# ── Phone OTP Tier-2 — SMS (only when SMS_PROVIDER=inforu | twilio) ──────────
# Inforu:  --set-secrets INFORU_API_KEY=inforu-api-key:latest
# INFORU_SENDER_ID=Aurora
# Twilio:  --set-secrets TWILIO_ACCOUNT_SID=twilio-account-sid:latest,TWILIO_AUTH_TOKEN=twilio-auth-token:latest
# TWILIO_FROM_NUMBER=<twilio trial/test number>

# ── KYC documents — GCS (KYC_BACKEND=gcs), KEYLESS via Workload Identity ─────
# NO exported key / secret — signing uses the IAM signBlob API with the runtime
# SA's ambient credentials (org-policy iam.disableServiceAccountKeyCreation safe).
# Required IAM on the runtime SA (aurora-run@…) — these are bindings, not env:
#   • roles/iam.serviceAccountTokenCreator on ITSELF  (enables signBlob — keyless signing)
#   • roles/storage.objectCreator  on the bucket      (browser PUT lands the object)
#   • roles/storage.objectViewer   on the bucket      (finalize downloads it to hash — objectCreator alone 403s)
# Verify all three live (run as the runtime SA — on Cloud Run, or IMPERSONATE_SA=…):
#   python3 scripts/verify_kyc_key.py <bucket>
GCS_BUCKET_KYC=asg-kyc-sandbox     # a throwaway sandbox bucket — NEVER the prod 7-year-retention asg-kyc-prod
# GCS_SIGNING_SA_EMAIL=aurora-run@<project>.iam.gserviceaccount.com   # optional — auto-derived from ambient creds on Cloud Run

# ── Payments — PayPlus (PAYPLUS_BACKEND=production + sandbox creds/URL) ───────
# SECRET: --set-secrets PAYPLUS_API_KEY=payplus-api-key:latest,PAYPLUS_TERMINAL_NUMBER=payplus-terminal-number:latest
#   (use SANDBOX merchant key + terminal — _payplus_creds() rejects empty / "YOUR_..." placeholders)
PAYPLUS_API_BASE=<PayPlus SANDBOX REST base URL>   # obtain from the PayPlus merchant portal — do NOT point at restapi.payplus.co.il (prod)

# ── Rate limiting (supporting) ───────────────────────────────────────────────
RATE_LIMIT_BACKEND=memory          # single-instance sandbox; use redis only if multi-instance
# REDIS_URL=<sandbox memorystore url>   # only if RATE_LIMIT_BACKEND=redis

# ── Frontend (business-portal — separate build-time env, NOT this service) ───
# NEXT_PUBLIC_AURORA_API_BASE=https://<nonprod-api-host>   # baked into the client bundle; must be a public host

# =============================================================================
# Example one-shot deploy (non-prod service) — selectors as env, creds as secrets:
#
#   gcloud run deploy aurora-api-nonprod \
#     --image <nonprod-image> \
#     --set-env-vars OTP_BACKEND=production,KYC_BACKEND=gcs,PAYPLUS_BACKEND=production,SMS_PROVIDER=stub,SECRET_BACKEND=env,AURORA_RUNTIME=cloud_run,SENDGRID_FROM=otp@sandbox.aurora-lts.example,GCS_BUCKET_KYC=asg-kyc-sandbox,PAYPLUS_API_BASE=<sandbox-url>,RATE_LIMIT_BACKEND=memory \
#     --set-secrets SENDGRID_API_KEY=sendgrid-api-key:latest,GCS_KYC_SA_KEY_JSON=gcs-kyc-sa-key:latest,PAYPLUS_API_KEY=payplus-api-key:latest,PAYPLUS_TERMINAL_NUMBER=payplus-terminal-number:latest
#
# The paired-credential startup check (app/config/backend_check.py) will HARD-FAIL
# the boot if a selector is flipped without its matching secret — so a half-flip
# is caught at deploy, not at the first real OTP/upload/charge.
# =============================================================================
